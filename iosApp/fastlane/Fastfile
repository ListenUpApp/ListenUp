default_platform(:ios)

platform :ios do
  desc "Build signed Release and upload to TestFlight"
  lane :beta do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],   # decoded .p8 contents
      is_key_content_base64: false,
    )

    # Set versions: marketing from VERSION input, build number from CI run number.
    increment_version_number(version_number: options[:version]) if options[:version]
    increment_build_number(build_number: options[:build_number]) if options[:build_number]

    build_app(
      scheme: "ListenUp",
      configuration: "Release",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
