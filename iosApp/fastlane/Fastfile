default_platform(:ios)

platform :ios do
  desc "Build signed Release and upload to TestFlight"
  lane :beta do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],   # decoded .p8 contents
      is_key_content_base64: false,
    )

    # Inject versions as build-setting overrides. The project sets literal
    # MARKETING_VERSION / CURRENT_PROJECT_VERSION (Config.xcconfig + pbxproj) with no
    # apple-generic versioning, so agvtool/increment_* would no-op. Command-line xcargs
    # overrides win over both the xcconfig and the pbxproj at build time.
    version_args = []
    version_args << "MARKETING_VERSION=#{options[:version]}" if options[:version]
    version_args << "CURRENT_PROJECT_VERSION=#{options[:build_number]}" if options[:build_number]

    build_app(
      scheme: "ListenUp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: version_args.join(" "),
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
